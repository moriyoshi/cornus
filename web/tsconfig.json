{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "strict": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    // The in-src mock is also loaded by the native-Node dev server (mock/server.ts),
    // which resolves value imports only with an explicit .ts extension. Vite/esbuild
    // and this flag accept them too; noEmit keeps tsc a type-check-only gate (Vite
    // emits the build).
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "types": ["vite/client"]
  },
  "include": ["src"]
}
